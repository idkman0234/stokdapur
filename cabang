<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>StokDapur - Cabang</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Mono:wght@400;500&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0d0d0b;
  --surface: #161612;
  --surface2: #1e1e19;
  --border: #2a2a22;
  --accent: #e8c547;
  --accent2: #c4522a;
  --text: #f0ece0;
  --muted: #7a7a6a;
  --green: #5a9e6f;
  --red: #c4522a;
  --yellow: #e8c547;
  --blue: #5a8fe8;
  --nav-h: 68px;
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}

* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }

html, body {
  height: 100%;
  background: var(--bg);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  overflow: hidden;
}

/* ── PAGES ── */
.app { height: 100dvh; display: flex; flex-direction: column; }
.pages { flex: 1; overflow: hidden; position: relative; }
.page {
  position: absolute; inset: 0; overflow-y: auto; -webkit-overflow-scrolling: touch;
  padding-bottom: calc(var(--nav-h) + var(--safe-bottom) + 1rem);
  opacity: 0; pointer-events: none; transition: opacity 0.2s;
}
.page.active { opacity: 1; pointer-events: all; }

/* ── TOP BAR ── */
.topbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1rem 1.25rem 0.75rem; background: rgba(13,13,11,0.97);
  border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 50; backdrop-filter: blur(12px);
}
.logo { font-family: 'Playfair Display', serif; font-size: 1.35rem; font-weight: 900; letter-spacing: -0.02em; }
.logo span { color: var(--accent); }
.topbar-date { font-family: 'DM Mono', monospace; font-size: 0.65rem; color: var(--muted); text-align: right; line-height: 1.4; }

/* ── BOTTOM NAV ── */
.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0; height: calc(var(--nav-h) + var(--safe-bottom));
  background: rgba(22,22,18,0.98); border-top: 1px solid var(--border); display: flex; backdrop-filter: blur(16px); z-index: 100;
}
.nav-item {
  flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.25rem;
  cursor: pointer; color: var(--muted); transition: color 0.15s; padding-bottom: var(--safe-bottom);
  border: none; background: transparent; font-family: 'DM Sans', sans-serif;
}
.nav-item.active { color: var(--accent); }
.nav-icon { font-size: 1.4rem; line-height: 1; }
.nav-label { font-size: 0.6rem; font-family: 'DM Mono', monospace; letter-spacing: 0.06em; text-transform: uppercase; }

/* ── STATS GRID ── */
.stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; padding: 1rem 1rem 0; }
.stat-card { background: var(--surface); border: 1px solid var(--border); padding: 1rem 1.1rem; position: relative; overflow: hidden; }
.stat-card::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px; }
.stat-card.c-green::after { background: var(--green); }
.stat-card.c-yellow::after { background: var(--yellow); }
.stat-card.c-red::after { background: var(--red); }
.stat-card.c-blue::after { background: var(--blue); }
.stat-label { font-family: 'DM Mono', monospace; font-size: 0.62rem; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.35rem; }
.stat-value { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; line-height: 1; }
.c-green .stat-value { color: var(--green); }
.c-yellow .stat-value { color: var(--yellow); }
.c-red .stat-value { color: var(--red); }
.c-blue .stat-value { color: var(--blue); }

/* ── SECTION HEADER ── */
.sec-head { display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 1rem 0.5rem; }
.sec-title { font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; }

/* ── ITEM CARDS ── */
.item-list { padding: 0 1rem; display: flex; flex-direction: column; gap: 0.6rem; }
.item-card { background: var(--surface); border: 1px solid var(--border); padding: 0.9rem 1rem; display: flex; align-items: center; gap: 0.85rem; }
.item-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.item-dot.ok { background: var(--green); box-shadow: 0 0 6px rgba(90,158,111,0.5); }
.item-dot.low { background: var(--yellow); box-shadow: 0 0 6px rgba(232,197,71,0.5); }
.item-dot.habis { background: var(--red); box-shadow: 0 0 6px rgba(196,82,42,0.5); }
.item-info { flex: 1; min-width: 0; }
.item-name { font-weight: 600; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.item-meta { font-family: 'DM Mono', monospace; font-size: 0.68rem; color: var(--muted); margin-top: 0.15rem; }
.item-right { text-align: right; flex-shrink: 0; }
.item-qty { font-family: 'DM Mono', monospace; font-size: 1.1rem; font-weight: 500; }
.item-qty.ok { color: var(--green); }
.item-qty.low { color: var(--yellow); }
.item-qty.habis { color: var(--red); }
.item-unit { font-family: 'DM Mono', monospace; font-size: 0.65rem; color: var(--muted); }

/* ── ALERT CARDS ── */
.alert-list { padding: 0 1rem; display: flex; flex-direction: column; gap: 0.5rem; }
.alert-card { display: flex; align-items: center; gap: 0.8rem; padding: 0.8rem 1rem; border: 1px solid; }
.alert-card.low { background: rgba(232,197,71,0.06); border-color: rgba(232,197,71,0.25); }
.alert-card.habis { background: rgba(196,82,42,0.06); border-color: rgba(196,82,42,0.25); }
.alert-icon { font-size: 1.1rem; }
.alert-text { flex: 1; }
.alert-name { font-size: 0.85rem; font-weight: 600; }
.alert-sub { font-family: 'DM Mono', monospace; font-size: 0.68rem; color: var(--muted); margin-top: 0.1rem; }

/* ── SEARCH & CHIPS ── */
.search-bar { padding: 0.75rem 1rem; position: relative; }
.search-bar input { width: 100%; background: var(--surface); border: 1px solid var(--border); color: var(--text); font-family: 'DM Mono', monospace; font-size: 0.82rem; padding: 0.75rem 1rem 0.75rem 2.5rem; outline: none; border-radius: 0; -webkit-appearance: none; }
.search-bar input:focus { border-color: var(--accent); }
.search-bar::before { content: '⌕'; position: absolute; left: 1.7rem; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 1rem; pointer-events: none; }
.chips { display: flex; gap: 0.5rem; padding: 0 1rem 0.75rem; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
.chips::-webkit-scrollbar { display: none; }
.chip { flex-shrink: 0; font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.06em; padding: 0.35rem 0.75rem; border: 1px solid var(--border); color: var(--muted); background: var(--surface); cursor: pointer; white-space: nowrap; transition: all 0.15s; }
.chip.active { border-color: var(--accent); color: var(--accent); background: rgba(232,197,71,0.08); }

/* ── STOK UBAH PAGE ── */
.stok-form { padding: 1rem; display: flex; flex-direction: column; gap: 1rem; }
.form-field { display: flex; flex-direction: column; gap: 0.4rem; }
.form-label { font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; color: var(--muted); text-transform: uppercase; }
.form-input, .form-select { background: var(--surface); border: 1px solid var(--border); color: var(--text); font-family: 'DM Mono', monospace; font-size: 0.9rem; padding: 0.8rem 1rem; outline: none; width: 100%; -webkit-appearance: none; border-radius: 0; }
.form-input:focus, .form-select:focus { border-color: var(--accent); }
.toggle-row { display: grid; grid-template-columns: 1fr; gap: 0.5rem; }
.toggle-btn { padding: 1rem; font-family: 'DM Mono', monospace; font-size: 0.8rem; letter-spacing: 0.06em; text-transform: uppercase; border: 1px solid var(--red); background: rgba(196,82,42,0.1); color: var(--red); display: flex; align-items: center; justify-content: center; gap: 0.4rem; pointer-events: none; }
.big-btn { width: 100%; padding: 1rem; font-family: 'DM Mono', monospace; font-size: 0.85rem; letter-spacing: 0.08em; text-transform: uppercase; background: var(--accent); color: #0d0d0b; border: none; cursor: pointer; font-weight: 500; transition: opacity 0.15s; }
.big-btn:active { opacity: 0.8; }
.stok-display { background: var(--surface2); border: 1px solid var(--border); padding: 1rem; margin-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: center; }
.stok-display .label { font-family: 'DM Mono', monospace; font-size: 0.7rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
.stok-display .value { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 700; color: var(--accent); }

/* ── LOG & EMPTY ── */
.log-list { padding: 0 1rem; display: flex; flex-direction: column; gap: 0.5rem; }
.log-item { display: flex; gap: 0.75rem; background: var(--surface); border: 1px solid var(--border); padding: 0.8rem 1rem; }
.log-dot { width: 8px; height: 8px; border-radius: 50%; margin-top: 0.3rem; flex-shrink: 0; }
.log-dot.add { background: var(--green); }
.log-dot.edit { background: var(--yellow); }
.log-dot.del { background: var(--red); }
.log-body { flex: 1; min-width: 0; }
.log-text { font-size: 0.8rem; color: var(--muted); line-height: 1.5; }
.log-text strong { color: var(--text); }
.log-time { font-family: 'DM Mono', monospace; font-size: 0.62rem; color: rgba(122,122,106,0.6); margin-top: 0.2rem; }
.empty { text-align: center; padding: 3rem 1rem; color: var(--muted); font-family: 'DM Mono', monospace; font-size: 0.78rem; line-height: 2; }
.ghost-btn { background: transparent; border: 1px solid var(--border); color: var(--muted); font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.4rem 0.8rem; cursor: pointer; }

/* DESKTOP: expand to 2-col layout */
@media (min-width: 600px) {
  .pages { max-width: 480px; margin: 0 auto; }
  .bottom-nav { max-width: 480px; left: 50%; transform: translateX(-50%); }
}
</style>
</head>
<body>
<div class="app">
  <div class="pages">

    <div class="page active" id="page-home">
      <div class="topbar">
        <div class="logo">Stok<span>Cabang</span></div>
        <div class="topbar-date" id="headerDate"></div>
      </div>

      <div class="stats-grid">
        <div class="stat-card c-green">
          <div class="stat-label">Total Item</div>
          <div class="stat-value" id="statTotal">0</div>
        </div>
        <div class="stat-card c-yellow">
          <div class="stat-label">Menipis</div>
          <div class="stat-value" id="statLow">0</div>
        </div>
        <div class="stat-card c-red">
          <div class="stat-label">Stok Habis</div>
          <div class="stat-value" id="statHabis">0</div>
        </div>
        <div class="stat-card c-blue">
          <div class="stat-label">Kategori</div>
          <div class="stat-value" id="statKat">0</div>
        </div>
      </div>

      <div id="alertSection" style="display:none">
        <div class="sec-head">
          <div class="sec-title">⚠ Perlu Perhatian</div>
        </div>
        <div class="alert-list" id="alertList"></div>
      </div>

      <div class="sec-head">
        <div class="sec-title">Semua Stok</div>
        <button class="ghost-btn" onclick="gotoPage('stok')">Lihat →</button>
      </div>
      <div class="item-list" id="homeItemList"></div>
    </div>

    <div class="page" id="page-stok">
      <div class="topbar">
        <div class="logo">Stok<span>Cabang</span></div>
        <div class="topbar-date">Daftar Bahan</div>
      </div>

      <div class="search-bar">
        <input type="search" id="searchInput" placeholder="Cari nama, kategori..." oninput="renderStokPage()">
      </div>

      <div class="chips" id="chipContainer">
        <div class="chip active" data-filter="" onclick="setChip(this)">Semua</div>
        <div class="chip" data-filter="ok" onclick="setChip(this)">✓ Aman</div>
        <div class="chip" data-filter="low" onclick="setChip(this)">! Menipis</div>
        <div class="chip" data-filter="habis" onclick="setChip(this)">✗ Habis</div>
      </div>

      <div class="item-list" id="stokItemList"></div>
      <div id="stokEmpty" class="empty" style="display:none">Tidak ada item.</div>
    </div>

    <div class="page" id="page-ubah">
      <div class="topbar">
        <div class="logo">Stok<span>Cabang</span></div>
        <div class="topbar-date">Pemakaian Stok</div>
      </div>

      <div class="stok-form">
        <div class="form-field">
          <div class="form-label">Pilih Item</div>
          <select class="form-select" id="quickItem" onchange="updateStokDisplay()">
            <option value="">— pilih bahan —</option>
          </select>
        </div>

        <div id="stokDisplayWrap" style="display:none">
          <div class="stok-display">
            <div>
              <div class="label">Stok Saat Ini</div>
              <div class="value" id="currentStokVal">0</div>
            </div>
            <div style="text-align:right">
              <div class="label">Satuan</div>
              <div style="font-family:'DM Mono',monospace;font-size:1rem;color:var(--muted)" id="currentSatuanVal">—</div>
            </div>
          </div>
        </div>

        <div class="form-field">
          <div class="form-label">Tipe Perubahan</div>
          <div class="toggle-row">
            <button class="toggle-btn" id="btnKeluar">▼ Pemakaian (Keluar)</button>
          </div>
        </div>

        <div class="form-field">
          <div class="form-label">Jumlah Pemakaian</div>
          <input type="number" class="form-input" id="quickQty" placeholder="0" min="0" inputmode="decimal">
        </div>

        <div class="form-field">
          <div class="form-label">Keterangan (opsional)</div>
          <input type="text" class="form-input" id="quickNote" placeholder="cth: dibuat bubur porsi...">
        </div>

        <button class="big-btn" onclick="submitQuick()">Simpan Pemakaian</button>
      </div>

      <div class="sec-head" style="margin-top:0.5rem">
        <div class="sec-title">Riwayat</div>
      </div>
      <div class="log-list" id="logList"></div>
    </div>

  </div>

  <nav class="bottom-nav">
    <button class="nav-item active" id="nav-home" onclick="gotoPage('home')">
      <span class="nav-icon">⌂</span>
      <span class="nav-label">Beranda</span>
    </button>
    <button class="nav-item" id="nav-stok" onclick="gotoPage('stok')">
      <span class="nav-icon">☰</span>
      <span class="nav-label">Stok</span>
    </button>
    <button class="nav-item" id="nav-ubah" onclick="gotoPage('ubah')">
      <span class="nav-icon">⇅</span>
      <span class="nav-label">Pakai Stok</span>
    </button>
  </nav>
</div>

<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
  import { 
    getFirestore, collection, onSnapshot, doc, setDoc, updateDoc, query, orderBy, limit 
  } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

  // ⚠️ GANTI KODE DI BAWAH INI DENGAN KUNCI FIREBASE MILIK ANDA
  const firebaseConfig = {
    apiKey: "AIzaSyDmGGM7qE440ztmVZ8SSdB...",
    authDomain: "stokdapurku-b76cb.firebaseapp.com",
    projectId: "stokdapurku-b76cb",
    storageBucket: "stokdapurku-b76cb.appspot.com",
    messagingSenderId: "619986157752",
    appId: "1:619986157752:web:eefc28353..."
  };

  const app = initializeApp(firebaseConfig);
  const db = getFirestore(app);

  // ── DATA GLOBAL ──
  let items = [];
  let logs  = [];
  let activeChipFilter = '';

  // HUBUNGKAN FIREBASE SECARA REAL-TIME (STOK BAHAN)
  onSnapshot(collection(db, "items"), (snapshot) => {
    items = [];
    snapshot.forEach((doc) => {
      items.push({ id: doc.id, ...doc.data() });
    });
    renderAll();
    if (document.getElementById('page-ubah').classList.contains('active')) {
      renderQuickSelect();
    }
  });

  // HUBUNGKAN FIREBASE SECARA REAL-TIME (RIWAYAT LOG)
  const logQuery = query(collection(db, "logs"), orderBy("timestamp", "desc"), limit(60));
  onSnapshot(logQuery, (snapshot) => {
    logs = [];
    snapshot.forEach((doc) => {
      logs.push(doc.data());
    });
    renderLog();
  });

  // ── UTILS BERSANDAR DATABASE ──
  function getStatus(i) {
    return i.stok <= 0 ? 'habis' : i.stok < i.min ? 'low' : 'ok';
  }

  function now() {
    return new Date().toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'});
  }

  async function addLog(type, text) {
    const logId = Date.now().toString();
    await setDoc(doc(db, "logs", logId), {
      type,
      text,
      time: now(),
      timestamp: Date.now(),
      user: "Cabang" // Menandakan aktivitas dilakukan oleh cabang
    });
  }

  // ── NAVIGATION ──
  window.gotoPage = function(name) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    document.getElementById('page-'+name).classList.add('active');
    document.getElementById('nav-'+name).classList.add('active');
    document.getElementById('page-'+name).scrollTop = 0;
    if (name === 'ubah') renderQuickSelect();
  }

  // ── RENDER ENGINE ──
  function renderAll() {
    renderDate();
    renderStats();
    renderHomePage();
    renderStokPage();
    renderLog();
  }

  function renderDate() {
    const d = new Date();
    document.getElementById('headerDate').innerHTML =
      d.toLocaleDateString('id-ID',{weekday:'short',day:'numeric',month:'short'}).toUpperCase();
  }

  function renderStats() {
    document.getElementById('statTotal').textContent  = items.length;
    document.getElementById('statLow').textContent    = items.filter(i=>getStatus(i)==='low').length;
    document.getElementById('statHabis').textContent  = items.filter(i=>getStatus(i)==='habis').length;
    document.getElementById('statKat').textContent    = [...new Set(items.map(i=>i.kategori))].length;
  }

  // Kartu item di cabang tidak punya fungsi 'onclick' (tidak bisa edit)
  function itemCardHTML(item) {
    const s = getStatus(item);
    return `
      <div class="item-card">
        <div class="item-dot ${s}"></div>
        <div class="item-info">
          <div class="item-name">${item.nama}</div>
          <div class="item-meta">${item.kategori}${item.supplier ? ' · '+item.supplier : ''}</div>
        </div>
        <div class="item-right">
          <div class="item-qty ${s}">${item.stok}</div>
          <div class="item-unit">${item.satuan}</div>
        </div>
      </div>`;
  }

  function renderHomePage() {
    const alerts = items.filter(i => getStatus(i) !== 'ok');
    const alertSection = document.getElementById('alertSection');
    const alertList    = document.getElementById('alertList');

    if (alerts.length === 0) {
      alertSection.style.display = 'none';
    } else {
      alertSection.style.display = '';
      alertList.innerHTML = alerts.map(i => {
        const s = getStatus(i);
        const label = s === 'habis' ? 'Stok habis!' : `Sisa ${i.stok} ${i.satuan} (min: ${i.min})`;
        const icon  = s === 'habis' ? '✗' : '!';
        return `<div class="alert-card ${s}">
          <div class="alert-icon">${icon}</div>
          <div class="alert-text">
            <div class="alert-name">${i.nama}</div>
            <div class="alert-sub">${label}</div>
          </div>
        </div>`;
      }).join('');
    }

    const homeList = document.getElementById('homeItemList');
    const show = items.slice(0,5);
    homeList.innerHTML = show.map(i => itemCardHTML(i)).join('');
  }

  window.renderStokPage = function() {
    const q  = (document.getElementById('searchInput')?.value||'').toLowerCase();
    const st = activeChipFilter;

    let filtered = items.filter(i => {
      const mq = i.nama.toLowerCase().includes(q) || i.kategori.toLowerCase().includes(q);
      const ms = !st || getStatus(i) === st;
      return mq && ms;
    });

    const list  = document.getElementById('stokItemList');
    const empty = document.getElementById('stokEmpty');

    if (!filtered.length) {
      list.innerHTML = '';
      empty.style.display = 'block';
      return;
    }
    empty.style.display = 'none';
    list.innerHTML = filtered.map(i => itemCardHTML(i)).join('');
  }

  function renderLog() {
    const el = document.getElementById('logList');
    if (!logs.length) {
      el.innerHTML = '<div class="log-item"><div class="log-body"><div class="log-text">Belum ada aktivitas.</div></div></div>';
      return;
    }
    el.innerHTML = logs.map(l => `
      <div class="log-item">
        <div class="log-dot ${l.type}"></div>
        <div class="log-body">
          <div class="log-text">${l.text} <span style="font-size:0.6rem;color:var(--muted)">${l.user ? '('+l.user+')' : ''}</span></div>
          <div class="log-time">${l.time}</div>
        </div>
      </div>`).join('');
  }

  function renderQuickSelect() {
    const el = document.getElementById('quickItem');
    const cur = el.value;
    el.innerHTML = '<option value="">— pilih bahan —</option>' +
      items.map(i=>`<option value="${i.id}">${i.nama} (${i.stok} ${i.satuan})</option>`).join('');
    if (cur) el.value = cur;
    updateStokDisplay();
  }

  // ── CONTROLS & EVENTS ──
  window.setChip = function(el) {
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    el.classList.add('active');
    activeChipFilter = el.dataset.filter;
    renderStokPage();
  }

  window.updateStokDisplay = function() {
    const id  = document.getElementById('quickItem').value;
    const wrap = document.getElementById('stokDisplayWrap');
    if (!id) { wrap.style.display='none'; return; }
    const item = items.find(i=>i.id===id);
    if (!item) { wrap.style.display='none'; return; }
    wrap.style.display = '';
    document.getElementById('currentStokVal').textContent   = item.stok;
    document.getElementById('currentSatuanVal').textContent = item.satuan;
  }

  window.submitQuick = async function() {
    const id = document.getElementById('quickItem').value;
    if (!id) { alert('Pilih item dulu.'); return; }
    const qty = parseFloat(document.getElementById('quickQty').value);
    if (!qty || qty <= 0) { alert('Masukkan jumlah yang valid.'); return; }

    const item = items.find(i=>i.id===id);
    
    // Validasi supaya cabang tidak bisa membuat stok jadi minus
    if (item.stok - qty < 0) {
      alert(`Stok tidak cukup! Sisa stok saat ini hanya ${item.stok} ${item.satuan}.`);
      return;
    }

    const delta = qty * -1; // Dikunci hanya untuk pengurangan
    const newStok = Math.max(0, item.stok + delta);

    await updateDoc(doc(db, "items", id), { stok: newStok });

    const note = document.getElementById('quickNote').value || 'pemakaian';
    addLog('edit', `<strong>${item.nama}</strong>: ${delta} ${item.satuan} (${note}) → ${newStok}`);

    document.getElementById('quickQty').value  = '';
    document.getElementById('quickNote').value = '';
    updateStokDisplay();
  }

  // INIT NAVIGATION Default
  gotoPage('home');
</script>
</body>
</html>

